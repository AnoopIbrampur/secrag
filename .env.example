# Copy to .env and fill in. Only GEMINI_API_KEY is required (for answer
# generation + the faithfulness judge). Embeddings run locally — no key needed.
# Get a free key (no billing) at https://aistudio.google.com/apikey

GEMINI_API_KEY=your-gemini-key-here

# SEC requires a descriptive User-Agent with contact info on every request.
# https://www.sec.gov/os/webmaster-faq#developers
SEC_USER_AGENT=secrag-research aarnavdoddamane@gmail.com

# Models (override if you like)
ANSWER_MODEL=gemini-2.5-flash-lite
JUDGE_MODEL=gemini-2.5-flash-lite
EMBED_MODEL=BAAI/bge-small-en-v1.5
